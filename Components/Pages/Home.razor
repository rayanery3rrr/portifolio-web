@page "/"

<PageTitle>Home</PageTitle>

<section class="pagina-inicial">

    <section class="secao-banner">

        <div class="banner-principal">

            <p class="subtitulo-banner">
                Portfólio da Rayane
            </p>

            <h1 class="titulo-banner">
                Desenvolvendo ideias em experiências digitais
            </h1>

            <p class="texto-banner">
                Aqui você encontra minha trajetória, projetos,
                experiências e formas de contato.
            </p>

        </div>

    </section>

    <section class="secao-destaques"
             id="destaques"
             aria-label="Destaques do site">

        <article class="cartao-destaque cartao-claro">

            <span class="numero-destaque">
                01
            </span>

            <h2>
                Minha História
            </h2>

            <p>
                Conheça minha trajetória, meus objetivos
                e minha evolução dentro da tecnologia.
            </p>

            <a href="/historia">
                Conhecer percurso →
            </a>

        </article>

        <article class="cartao-destaque cartao-escuro">

            <span class="numero-destaque">
                02
            </span>

            <h2>
                Meu Currículo
            </h2>

            <p>
                Experiências, habilidades técnicas
                e projetos desenvolvidos.
            </p>

            <a href="/curriculo">
                Ver currículo →
            </a>

        </article>

        <article class="cartao-destaque cartao-destaque-contato">

            <span class="numero-destaque">
                03
            </span>

            <h2>
                Contato
            </h2>

            <p>
                Entre em contato para oportunidades,
                projetos ou networking.
            </p>

            <a href="/contato">
                Iniciar conversa →
            </a>

        </article>

    </section>

</section>